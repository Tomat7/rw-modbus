	$(TANGLE) $<

%.tex: %.web
#  способ, который следует применить (встроенные):
	$(WEAVE) $<

%.sh:

%: %.sh
#  способ, который следует применить (встроенные):
	cat $< >$@ 
	 chmod a+x $@

%.elc:

%.el:

(%): %
#  способ, который следует применить (встроенные):
	$(AR) $(ARFLAGS) $@ $<

%.out: %
#  способ, который следует применить (встроенные):
	@rm -f $@ 
	 cp $< $@

%.c: %.w %.ch
#  способ, который следует применить (встроенные):
	$(CTANGLE) $^ $@

%.tex: %.w %.ch
#  способ, который следует применить (встроенные):
	$(CWEAVE) $^ $@

%:: %,v
#  способ, который следует применить (встроенные):
	$(CHECKOUT,v)

%:: RCS/%,v
#  способ, который следует применить (встроенные):
	$(CHECKOUT,v)

%:: RCS/%
#  способ, который следует применить (встроенные):
	$(CHECKOUT,v)

%:: s.%
#  способ, который следует применить (встроенные):
	$(GET) $(GFLAGS) $(SCCS_OUTPUT_OPTION) $<

%:: SCCS/s.%
#  способ, который следует применить (встроенные):
	$(GET) $(GFLAGS) $(SCCS_OUTPUT_OPTION) $<

# Неявных правил: 92, терминальных: 5 (5,4%) терминал.


#include <stdio.h>
#include <cstdlib>

void var_size_test()
{
  int intvar;
  short shortvar;
  long longvar;
  long long ll_var;

  printf("int   size: %zd\n", sizeof(intvar));
  printf("short size: %zd\n", sizeof(shortvar));
  printf("long  size: %zd\n", sizeof(longvar));
  printf("llong size: %zd\n", sizeof(ll_var));

  int16_t i16;
  int32_t i32;
  int64_t i64;

  printf("i16 size: %zd\n", sizeof(i16));
  printf("i32 size: %zd\n", sizeof(i32));
  printf("i64 size: %zd\n", sizeof(i64));

  float fl;
  double dbl;
  long double ldbl;

  printf("float    size: %zd\n", sizeof(fl));
  printf("double   size: %zd\n", sizeof(dbl));
  printf("long dbl size: %zd\n", sizeof(ldbl));

  exit(0);
}

// eof


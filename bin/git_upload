#!/bin/bash
#
RED='\033[0;91m'
GRE="\033[0;32m"
YEL="\033[0;93m"
YEB="\033[1;33m"
BLU='\033[0;94m'
WHI='\033[0;97m'
NC='\033[0m' # No Color
# =====================

cd ..

echo -e $YEB ==== ADD files ====
#clang-format -i *.cpp
#clang-format -i *.h
make clean
git add -v .

echo -e $YEB ==== COMMIT ====
git commit -a
##### -m $1

echo -e $YEB ==== PUSH ====
git push -v -f -u origin --all
git push -v -f github --all

echo -e $GRE ==== Finished...

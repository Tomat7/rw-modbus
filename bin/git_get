#!/bin/bash
#
# =======================
read -p "==== Warning! Will LOST ALL CHANGES! (Y/N): " ANS

if [ "$ANS" == "Y" ]
then
    echo ==== Doing git STASH.
    git stash -v
    echo ==== Doing git PULL.
    git pull -v 
    echo ==== Doing git STASH CLEAR.
    git stash -v clear
    echo ==== Finished.
else
    echo ==== Doing nothing. Relax and Bye!
fi
